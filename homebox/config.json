{
  "name": "Homebox",
  "version": "1.2.3",
  "slug": "homebox",
  "description": "Home inventory management system with Home Assistant conversation support",
  "url": "https://github.com/Amantux/ha-homebox-addon",
  "arch": [
    "amd64",
    "aarch64"
  ],
  "image": "ghcr.io/amantux/ha-homebox-addon/homebox",
  "startup": "application",
  "boot": "auto",
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:package-variant",
  "panel_title": "Homebox",
  "options": {
    "timezone": "UTC",
    "log_level": "info"
  },
  "schema": {
    "timezone": "str",
    "log_level": "list(debug|info|warning|error)"
  },
  "map": [
    "data:rw"
  ],
  "hassio_api": true,
  "hassio_role": "default",
  "ingress_stream": true
}
